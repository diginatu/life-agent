# Webcam device path
WEBCAM_DEVICE=/dev/video0

# Ollama configuration
OLLAMA_MODEL=gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434

# Output directories
LOG_DIR=./logs
CAPTURE_DIR=./captures

# Capture resolution
CAPTURE_WIDTH=640
CAPTURE_HEIGHT=480

# Policy: quiet hours (24h format)
QUIET_HOURS_START=23
QUIET_HOURS_END=7

# Policy: cooldown between actions (minutes)
COOLDOWN_MINUTES=30

# Policy: minimum confidence to act
CONFIDENCE_THRESHOLD=0.3
